{
  "manifest_version": 3,
  "name": "StrawsProxy",
  "version": "1.2",
  "key": "",
  "description": "Straws Proxy",
  "permissions": [
    "proxy",
    "storage",
    "tabs",
    "scripting",
    "sidePanel"
  ],
  "action": {
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "ui/css/*.css",
        "ui/js/*.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
