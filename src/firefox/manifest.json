{
  "manifest_version": 3,
  "name": "Straws",
  "version": "1.0",
  "description": "Powerful declarative proxy engine (Active Interceptor).",
  "browser_specific_settings": {
    "gecko": {
      "id": "straws@kaber420.com",
      "strict_min_version": "113.0"
    }
  },
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "storage",
    "webRequest",
    "proxy",
    "alarms",
    "nativeMessaging",
    "scripting",
    "tabs",
    "contextualIdentities",
    "cookies"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "sidebar_action": {
    "default_panel": "sidepanel.html",
    "default_icon": "icons/icon-48.png"
  },
  "action": {
    "default_title": "Open Straws"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
